generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id        String   @id @default(cuid())
  title     String
  filename  String
  content   String
  summary   String?
  fileSize  Int
  status    String   @default("processing")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analysis {
  id          String   @id @default(cuid())
  symbol      String
  type        String   @default("crypto")
  timeframe   String   @default("1D")
  direction   String?
  entryPrice  String?
  stopLoss    String?
  takeProfit1 String?
  takeProfit2 String?
  takeProfit3 String?
  confidence  String?
  analysis    String
  chartUrl    String?
  reasoning   String
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  symbol    String?
  imageUrl  String?
  createdAt DateTime @default(now())
}
